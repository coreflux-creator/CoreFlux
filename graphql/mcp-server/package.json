{
  "name": "mcp-server",
  "version": "1.0.0",
  "description": "MCP server exposing the CoreFlux GraphQL federation as typed tools to agentic AI clients (Claude Desktop, Cursor, Apollo agents).",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "bin": {
    "coreflux-mcp": "dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "graphql": "^16.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  }
}
