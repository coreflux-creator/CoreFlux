{
  "name": "subgraph-coreflux",
  "version": "1.0.0",
  "description": "CoreFlux GraphQL subgraph — owns canonical types (Placement / Person / Company). Resolvers proxy to the PHP REST API.",
  "private": true,
  "type": "module",
  "scripts": {
