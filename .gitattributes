# CoreFlux Git Attributes

# Mark module directories as subtrees for reference
# These directories are managed via git subtree
modules/people/** linguist-vendored
modules/accounting/** linguist-vendored

# Ensure consistent line endings
*.php text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.json text eol=lf
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

# ── Generated build artifacts: auto-resolve merges to "ours" ─────────────
# These files are regenerated by `yarn --cwd dashboard build` (Vite emits new
# content-hashed names + index.html, and sync_bundle.sh stamps .deploy-version).
# When two branches both rebuild they collide on these paths. The "ours" merge
# driver (registered via `scripts/setup-git.sh`) keeps the current branch's
# copy during a LOCAL merge instead of raising a conflict; the bundle is then
# refreshed by a deliberate rebuild on `main` at release time.
# NOTE: GitHub's web-UI merge does NOT honor merge drivers — merge locally.
spa-assets/**          merge=ours
/index.html            merge=ours
.deploy-version        merge=ours
dashboard/dist/**      merge=ours
app/assets/**          merge=ours
dashboard/assets/**    merge=ours
