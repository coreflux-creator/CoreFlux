# Environment files
*.env
*.env.*

# Node / build artifacts
node_modules/
dist/
.vite/
.cache/
__pycache__/
*.pyc

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# PHP / composer
vendor/

# Emergent internal
.emergent/cache/

# Local-only backup snapshots (NEVER commit — they exceed GitHub's 100 MB
# per-file limit and re-pushing them costs minutes per `git push`).
# Restore tarballs live on disk in /app/memory/backups/ but the MANIFEST.md
# tracking metadata IS committed so we have a paper trail in the repo.
memory/backups/*
!memory/backups/MANIFEST.md
!memory/backups/.gitkeep
*.tar.gz
config.local.php
-e 
