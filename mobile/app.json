{
  "expo": {
    "name": "CoreFlux",
    "slug": "coreflux-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.coreflux.mobile",
      "associatedDomains": ["applinks:app.coreflux.com"],
      "infoPlist": {
        "NSCameraUsageDescription": "CoreFlux uses the camera to capture receipts and supporting documents.",
        "NSPhotoLibraryUsageDescription": "CoreFlux needs access to your photo library to attach receipts to bills."
      }
    },
    "android": {
      "package": "com.coreflux.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "app.coreflux.com", "pathPrefix": "/approvals" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "data": [{ "scheme": "coreflux" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "CoreFlux needs access to your photos to attach receipts.",
          "cameraPermission": "CoreFlux needs access to the camera to capture receipts."
        }
      ],
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://app.coreflux.example.com",
      "buildChannel": "default"
    },
    "scheme": "coreflux"
  }
}
